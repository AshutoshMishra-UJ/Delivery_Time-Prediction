# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ========================================
# MLflow & DagsHub Configuration
# ========================================
# Get these from: https://dagshub.com/YOUR_USERNAME/YOUR_REPO/settings
MLFLOW_TRACKING_URI=https://dagshub.com/YOUR_USERNAME/swiggy-delivery-time-prediction.mlflow
DAGSHUB_USER_NAME=YOUR_DAGSHUB_USERNAME
DAGSHUB_REPO_NAME=swiggy-delivery-time-prediction
DAGSHUB_TOKEN=YOUR_DAGSHUB_TOKEN

# MLflow credentials (use DagsHub credentials)
MLFLOW_TRACKING_USERNAME=YOUR_DAGSHUB_USERNAME
MLFLOW_TRACKING_PASSWORD=YOUR_DAGSHUB_TOKEN

# ========================================
# AWS Configuration (Optional - if using S3)
# ========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket-name

# ========================================
# Model Configuration
# ========================================
MODEL_NAME=delivery_time_prediction_model
MODEL_STAGE=Production
MODEL_VERSION=latest

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# ========================================
# Database Configuration (Optional)
# ========================================
DATABASE_URL=sqlite:///./swiggy_predictions.db

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ========================================
# Application Settings
# ========================================
ENVIRONMENT=development  # development, staging, production
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# ========================================
# INSTRUCTIONS:
# ========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials
# 3. NEVER commit the .env file to Git (it's in .gitignore)
# 4. For DagsHub token: https://dagshub.com/user/settings/tokens
